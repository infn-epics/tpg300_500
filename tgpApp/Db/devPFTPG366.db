###############################################################################
# EPICS Database for Pfeiffer Vacuum TPG 366 MaxiGauge
# 6-channel total pressure measurement and control unit for ActiveLine gauges
#
# Macros:
#   P      - Device prefix (e.g. "VAC-TPG366")
#   R      - Record sub-prefix (default empty; colon separator is built-in)
#   PORT   - Asyn port name
###############################################################################

###############################################################################
# Scan trigger event (10-second periodic tasks)
###############################################################################
record(event, "$(P):$(R):iScan10Event") {
    field(SCAN, "10 second")
    field(VAL,  "$(P)-10")
    field(PINI, "YES")
}

###############################################################################
# Disable comms toggle
###############################################################################
record(bo, "$(P):$(R):DISABLE") {
    field(DESC, "Disable comms")
    field(PINI, "YES")
    field(VAL,  "$(DISABLE=0)")
    field(OMSL, "supervisory")
    field(ZNAM, "COMMS ENABLED")
    field(ONAM, "COMMS DISABLED")
}

###############################################################################
# Device identification
###############################################################################
record(stringin, "$(P):$(R):DEVTYPE") {
    field(DESC, "Device type")
    field(VAL,  "TPG366")
    field(DTYP, "Soft Channel")
    field(PINI, "YES")
}

record(stringin, "$(P):$(R):ARTNUMB") {
    field(DESC, "Article number")
    field(VAL,  "")
    field(DTYP, "Soft Channel")
    field(PINI, "YES")
}

record(stringin, "$(P):$(R):SERIALNUM") {
    field(DESC, "Serial number")
    field(VAL,  "")
    field(DTYP, "Soft Channel")
    field(PINI, "YES")
}

record(stringin, "$(P):$(R):FWVER") {
    field(DESC, "Firmware version")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_firmware_version $(PORT)")
    field(PINI, "YES")
}

record(stringin, "$(P):$(R):HWVER") {
    field(DESC, "Hardware version")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_hardware_version $(PORT)")
    field(PINI, "YES")
}

record(stringin, "$(P):$(R):IDN_RAW") {
    field(DESC, "Device identification raw")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto identify_device_raw $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(FLNK, "$(P):$(R):ParseIdentify")
}

record(aSub, "$(P):$(R):ParseIdentify") {
    field(INAM, "initParseSlots")
    field(SNAM, "parseSlots")
    field(FTA,  "STRING")
    field(INPA, "$(P):$(R):IDN_RAW CP")
    field(FTVA, "STRING")
    field(FTVB, "STRING")
    field(FTVC, "STRING")
    field(FTVD, "STRING")
    field(FTVE, "STRING")
    field(NOVA, "64")
    field(NOVB, "64")
    field(NOVC, "64")
    field(NOVD, "64")
    field(NOVE, "64")
    field(OUTA, "$(P):$(R):DEVTYPE PP")
    field(OUTB, "$(P):$(R):ARTNUMB PP")
    field(OUTC, "$(P):$(R):SERIALNUM PP")
    field(OUTD, "$(P):$(R):FWVER PP")
    field(OUTE, "$(P):$(R):HWVER PP")
}

###############################################################################
# Error status
# 0000=no error, 1000=ERROR, 0100=NO HWR, 0010=PAR, 0001=SYN
###############################################################################
record(mbbi, "$(P):$(R):ERROR") {
    field(DESC, "Device error status")
    field(DTYP, "stream")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(INP,  "@devPFTPG366.proto getErrorStatus $(PORT)")
    field(ZRST, "No error")
    field(ZRVL, "0")
    field(ONST, "Device error")
    field(ONVL, "8")
    field(ONSV, "MAJOR")
    field(TWST, "No hardware")
    field(TWVL, "4")
    field(TWSV, "INVALID")
    field(THST, "Invalid parameter")
    field(THVL, "2")
    field(THSV, "MINOR")
    field(FRST, "Syntax error")
    field(FRVL, "1")
    field(FRSV, "MINOR")
}

###############################################################################
# Units readback / setpoint
# 0=mbar/bar, 1=Torr, 2=Pascal, 3=Micron, 4=hPascal, 5=Volt
###############################################################################
record(mbbi, "$(P):$(R):UNITS_RB") {
    field(DESC, "Units readback")
    field(DTYP, "stream")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(INP,  "@devPFTPG366.proto getUnits $(PORT)")
    field(ZRST, "mbar/bar")
    field(ZRVL, "0")
    field(ONST, "Torr")
    field(ONVL, "1")
    field(TWST, "Pascal")
    field(TWVL, "2")
    field(THST, "Micron")
    field(THVL, "3")
    field(FRST, "hPascal")
    field(FRVL, "4")
    field(FVST, "Volt")
    field(FVVL, "5")
    info(INTEREST, "HIGH")
}

record(mbbo, "$(P):$(R):UNITS_SP") {
    field(DESC, "Units setpoint")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto setUnits $(PORT)")
    field(ZRST, "mbar/bar")
    field(ZRVL, "0")
    field(ONST, "Torr")
    field(ONVL, "1")
    field(TWST, "Pascal")
    field(TWVL, "2")
    field(THST, "Micron")
    field(THVL, "3")
    field(FRST, "hPascal")
    field(FRVL, "4")
    field(FVST, "Volt")
    field(FVVL, "5")
    field(FLNK, "$(P):$(R):UNITS_RB")
}

###############################################################################
# Underrange control
###############################################################################
record(bi, "$(P):$(R):UNDERRANGE_CTRL_RB") {
    field(DESC, "Underrange control readback")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_puc $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
}

record(bo, "$(P):$(R):UNDERRANGE_CTRL") {
    field(DESC, "Underrange control")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto set_puc $(PORT)")
    field(ZNAM, "OFF")
    field(ONAM, "ON")
    field(FLNK, "$(P):$(R):UNDERRANGE_CTRL_RB")
}

###############################################################################
# Operating hours
###############################################################################
record(longin, "$(P):$(R):OPHOURS") {
    field(DESC, "Operating hours")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_operating_hours $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(EGU,  "h")
}

###############################################################################
# Inner temperature
###############################################################################
record(longin, "$(P):$(R):TEMP") {
    field(DESC, "Inner device temperature")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_temperature $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(EGU,  "degC")
    field(HIHI, "50")
    field(HIGH, "40")
    field(HHSV, "MAJOR")
    field(HSV,  "MINOR")
}

###############################################################################
# Keylock
###############################################################################
record(bi, "$(P):$(R):KEYLOCK_RB") {
    field(DESC, "Keylock readback")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_keylock $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
    field(ZNAM, "Unlocked")
    field(ONAM, "Locked")
}

record(bo, "$(P):$(R):KEYLOCK") {
    field(DESC, "Keylock control")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto set_keylock $(PORT)")
    field(ZNAM, "Unlock")
    field(ONAM, "Lock")
    field(FLNK, "$(P):$(R):KEYLOCK_RB")
}

###############################################################################
# Gauge identification (slots)
###############################################################################
record(stringin, "$(P):$(R):SLOTS_RAW") {
    field(DESC, "Gauge IDs raw")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_gauge_ids($(P):$(R):SLOT1,$(P):$(R):SLOT2,$(P):$(R):SLOT3,$(P):$(R):SLOT4,$(P):$(R):SLOT5,$(P):$(R):SLOT6) $(PORT)")
    field(SCAN, "Event")
    field(EVNT, "$(P)-10")
}

record(stringin, "$(P):$(R):SLOT1") {
    field(DESC, "Gauge 1 type")
    field(VAL,  "")
}

record(stringin, "$(P):$(R):SLOT2") {
    field(DESC, "Gauge 2 type")
    field(VAL,  "")
}

record(stringin, "$(P):$(R):SLOT3") {
    field(DESC, "Gauge 3 type")
    field(VAL,  "")
}

record(stringin, "$(P):$(R):SLOT4") {
    field(DESC, "Gauge 4 type")
    field(VAL,  "")
}

record(stringin, "$(P):$(R):SLOT5") {
    field(DESC, "Gauge 5 type")
    field(VAL,  "")
}

record(stringin, "$(P):$(R):SLOT6") {
    field(DESC, "Gauge 6 type")
    field(VAL,  "")
}

###############################################################################
# MAC address
###############################################################################
record(stringin, "$(P):$(R):MAC") {
    field(DESC, "Ethernet MAC address")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_mac $(PORT)")
    field(PINI, "YES")
}

###############################################################################
# Ethernet config (raw)
###############################################################################
record(stringin, "$(P):$(R):ETH_RAW") {
    field(DESC, "Ethernet config raw")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto get_ethernet_raw $(PORT)")
    field(PINI, "YES")
}

###############################################################################
# CHANNEL 1 - Pressure, Status, Filter, Sensor Mode, Degas
###############################################################################
record(ai, "$(P):$(R):CH1:PRES") {
    field(DESC, "Channel 1 pressure")
    field(DTYP, "stream")
    field(INP,  "@devPFTPG366.proto getPressure(1,$(P):$(R):CH1:STAT) $(PORT)")
    field(SCAN, "1 second")
    field(PREC, "4")
    field(EGU,  "hPa")
    field(HOPR, "1000")
    field(LOPR, "0")
}

record(mbbi, "$(P):$(R):CH1:STAT") {
    field(DESC, "Channel 1 status")
    field(DTYP, "Soft Channel")
    field(ZRST, "OK")
    field(ZRVL, "0")
    field(ONST, "Underrange")
    field(ONVL, "1")
    field(ONSV, "MINOR")
    field(TWST, "Overrange")
    field(TWVL, "2")
    field(TWSV, "MINOR")
    field(THST, "Sensor error")
    field(THVL, "3")
    field(THSV, "MAJOR")
    field(FRST, "Sensor off")
    field(FRVL, "4")
    field(FRSV, "MINOR")
    field(FVST, "No gauge")
    field(FVVL, "5")
    field(FVSV, "INVALID")
    field(SXST, "ID error")
    field(SXVL, "6")
    field(SXSV, "MAJOR")
    info(INTEREST, "HIGH")
}

record(mbbo, "$(P):$(R):CH1:FILTER") {
    field(DESC, "Channel 1 filter")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto set_filter_1($(P):$(R):CH1:FILTER,$(P):$(R):CH1:FILTER_RB) $(PORT)")
    field(ZRST, "Off")
    field(ZRVL, "0")
    field(ONST, "Fast")
    field(ONVL, "1")
    field(TWST, "Normal")
    field(TWVL, "2")
    field(THST, "Slow")
    field(THVL, "3")
    field(FLNK, "$(P):$(R):CH1:FILTER_RB")
}

record(mbbi, "$(P):$(R):CH1:FILTER_RB") {
    field(DESC, "Channel 1 filter readback")
    field(DTYP, "Soft Channel")
    field(ZRST, "Off")
    field(ZRVL, "0")
    field(ONST, "Fast")
    field(ONVL, "1")
    field(TWST, "Normal")
    field(TWVL, "2")
    field(THST, "Slow")
    field(THVL, "3")
}

record(mbbo, "$(P):$(R):CH1:SEN") {
    field(DESC, "Channel 1 sensor on/off")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto set_sensor_mode_1($(P):$(R):CH1:SEN,$(P):$(R):CH1:SEN_RB) $(PORT)")
    field(ZRST, "No change")
    field(ZRVL, "0")
    field(ONST, "Off")
    field(ONVL, "1")
    field(TWST, "On")
    field(TWVL, "2")
}

record(mbbi, "$(P):$(R):CH1:SEN_RB") {
    field(DESC, "Channel 1 sensor status")
    field(DTYP, "Soft Channel")
    field(ZRST, "Cannot switch")
    field(ZRVL, "0")
    field(ONST, "Off")
    field(ONVL, "1")
    field(TWST, "On")
    field(TWVL, "2")
    info(INTEREST, "HIGH")
}

record(bo, "$(P):$(R):CH1:DEGAS") {
    field(DESC, "Channel 1 degas")
    field(DTYP, "stream")
    field(OUT,  "@devPFTPG366.proto set_degas_1($(P):$(R):CH1:DEGAS,$(P):$(R):CH1:DEGAS_RB) $(PORT)")
    field(ZNAM, "Off")
    field(ONAM, "On (3 min)")
}

record(bi, "$(P):$(R):CH1:DEGAS_RB") {
    field(DESC, "Channel 1 degas status")
    field(DTYP, "Soft Channel")
    field(ZNAM, "Off")
    field(ONAM, "Active")
}

