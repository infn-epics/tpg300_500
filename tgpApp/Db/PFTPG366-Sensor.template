    field (SCAN, "$(SLOWSCAN=10 second)")
    field (INP,  "@devPFTPG366.proto getUnits $(PORT)")
    field (ZRST, "mbar/bar") field (ZRVL, "0")
    field (ONST, "Torr")     field (ONVL, "1")
    field (TWST, "Pascal")   field (TWVL, "2")
    field (THST, "Micron")   field (THVL, "3")
    field (FRST, "hPascal")  field (FRVL, "4")
    field (FVST, "Volt")     field (FVVL, "5")
    field (ASG,  "READONLY")
}

