record (mbbi, "$(CONTROLLER):ERROR")
{
    field (DESC, "Device error status")
    field (DTYP, "stream")
    field (SCAN, "$(SLOWSCAN=10 second)")
    field (INP,  "@devPFTPG366.proto getErrorStatus $(PORT)")
    field (ZRST, "No error")     field (ZRVL, "0")
    field (ONST, "Device error") field (ONVL, "8")  field (ONSV, "MAJOR")
    field (TWST, "No hardware")  field (TWVL, "4")  field (TWSV, "INVALID")
    field (THST, "Invalid param") field (THVL, "2") field (THSV, "MINOR")
    field (FRST, "Syntax error") field (FRVL, "1")  field (FRSV, "MINOR")
    field (ASG,  "READONLY")
}

